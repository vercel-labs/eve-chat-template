DATABASE_URL=
BETTER_AUTH_SECRET=
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Required: file uploads use Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Optional: override the app origin for a custom production domain.
BETTER_AUTH_URL=

# Optional: enable hosted Vercel Connect integrations.
SLACK_CONNECTOR=
LINEAR_CONNECTOR=
NOTION_CONNECTOR=
SENTRY_CONNECTOR=

# Optional: generate embeddings for the knowledge base.
# Embeddings route through the Vercel AI Gateway on the agent's existing credential.
# No separate API key needed. Provider is swappable via EMBEDDING_PROVIDER.
# EMBEDDING_PROVIDER=gateway
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional: override the default perception reader (local = app Postgres; http = external runtime).
# PROJECTION_READER=local

# Optional: override the default Lab provider (local = app tables; http = external Lab).
# LAB_PROVIDER=local

# Optional: Dynamic Projections motor (lib/projections).
# Base URL do runtime de projeção; o reader fala POST <url>/projection (modo rows).
# Sem isso, o motor usa o local SceneReader (app Postgres) por padrão.
DREAM_MACHINE_RUNTIME_URL=
# Bearer opcional para o /projection (leitura; zero capacidade de escrita).
DREAM_MACHINE_RUNTIME_TOKEN=
# Timeout do reader em ms (default 8000).
DREAM_MACHINE_RUNTIME_TIMEOUT_MS=

# Optional: seam do Lab (autoridade). A tool propose_effect despacha POST <url>/effect
# após aprovação humana (airlock). Sem isso, o Lab local assume por padrão.
DREAM_MACHINE_LAB_URL=
DREAM_MACHINE_LAB_TOKEN=
DREAM_MACHINE_LAB_TIMEOUT_MS=
